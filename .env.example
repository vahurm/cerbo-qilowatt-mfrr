# =============================================================================
# cerbo-qilowatt-mfrr — per-site configuration
# =============================================================================
# Copy this file to a private, UNTRACKED location (e.g. /data/qw-agent.env on
# the Cerbo) and fill in the real values. NEVER commit a filled-in .env.
#
#   cp .env.example /data/qw-agent.env   # then edit on the Cerbo
#
# All values are read by agent/qw_agent.py at startup.
# =============================================================================

# --- Qilowatt cloud (per-device, from Qilowatt support) ---------------------
# QW_DEVICE_ID is the MQTT TOPIC identity: telemetry is published to
# Q/<QW_DEVICE_ID>/SENSOR and commands arrive on Q/<QW_DEVICE_ID>/cmnd/backlog.
# In a qilowatt-ha install this is the config-entry field "inverter_id"
# (a UUID, e.g. 00000000-0000-0000-0000-000000000000), NOT the account-level
# "device_id" hex string.
# Using the wrong id silently breaks BOTH telemetry (empty dashboard) and
# command reception (mFRR signals never arrive).
QW_DEVICE_ID=REPLACE_WITH_INVERTER_ID
QW_MQTT_USER=REPLACE_WITH_MQTT_USER
QW_MQTT_PASS=REPLACE_WITH_MQTT_PASS
QW_MQTT_HOST=mqtt.qilowatt.it
QW_MQTT_PORT=8883
QW_MQTT_TLS=1

# --- Telemetry profile (site PV topology) -----------------------------------
# dc_coupled = PV on the battery DC bus via Victron MPPT (/Dc/Pv/Power).  <- site A
# ac_coupled = PV inverter on the MultiPlus AC output (/Ac/PvOnOutput).   <- site B
QW_TELEMETRY_PROFILE=dc_coupled

# --- mFRR state machine + actuators -----------------------------------------
# Asymmetric power clamp (the script enforces these per direction):
#   import  = positive setpoint (frrdown), export = |negative| setpoint (frrup).
QW_MAX_IMPORT_W=15000
QW_MAX_EXPORT_W=15000
# Actuator script paths (defaults match the standard /data install).
QW_DESS_TOGGLE_SCRIPT=/data/qw_dess_toggle.sh
QW_GRID_SETPOINT_SCRIPT=/data/qw_grid_setpoint.sh
# Two-level SOC floor: on this Venus build the Dynamic ESS delegate reads its
# floor from the SINGLE ESS min-SOC (CGwacs/BatteryLife/MinimumSocLimit ->
# /Control/ActiveSocLimit), NOT from DynamicEss/MinSoc, so arbitrage and mFRR
# share one floor. To let normal DESS arbitrage rest at X (the dashboard
# "Minimum SOC" slider) while an mFRR event may discharge deeper to Y (Y < X),
# set QW_MFRR_MIN_SOC=Y. qw_dess_toggle.sh then lowers the floor to Y for the
# event and restores X afterwards (atomic save/restore, same as DESS Mode).
# EMPTY = never touch the floor (single floor = the slider). Passed through to
# the toggle script via the agent's inherited environment.
QW_MFRR_MIN_SOC=
# Qilowatt sources that count as an active mFRR event (comma-separated).
QW_MFRR_SOURCES=fusebox,kratt
# Settle delay between DESS-off and the first setpoint write (seconds).
QW_DESS_OFF_DELAY_S=2
# Failsafes: revert if the QW link is lost this long while ACTIVE, or if a single
# event runs longer than this (seconds).
QW_MQTT_LOST_FAILSAFE_S=300
QW_MAX_EVENT_S=1800
# Failsafe check interval (seconds).
QW_TICK_INTERVAL_S=10
# Liveness watchdog: if the QW cloud link stays down this long, the agent exits
# so the service supervisor restarts it. Recovers from a permanent qilowatt-py
# shutdown (e.g. after repeated auth failures) that a plain supervisor can't see
# because the process stays alive. 0 disables.
QW_LINK_RESTART_S=600
# Zombie-subscription watchdog: qilowatt-py keeps a session marked "connected"
# even when the WORKMODE re-subscribe fails, so telemetry keeps flowing while the
# agent goes permanently deaf to commands. If the transport is connected but the
# command topic stays unsubscribed this long, exit for a fresh restart. 0 disables.
QW_SUBSCRIBE_GRACE_S=120
# Backstop for silently deaf sessions that still report subscribed: if NO WORKMODE
# command is received for this long while the agent is IDLE, exit for a fresh QW
# subscription. A received command (incl. periodic NORMAL heartbeats) proves the
# subscription is live, so a site that keeps getting commands never restarts; only
# genuine command-silence triggers a refresh. Set comfortably above the longest
# expected gap between commands (e.g. hourly heartbeats -> 6h leaves 6x margin).
# An in-process reconnect can't restart qilowatt-py's telemetry timers, so a clean
# process restart is the only safe refresh. 0 disables.
QW_IDLE_REFRESH_S=21600
# Dry-run: log intended actions but DO NOT touch dbus (validation/parallel phase).
QW_DRY_RUN=0

# --- Telemetry --------------------------------------------------------------
# GridExportLimit reported to Qilowatt when MaxFeedInPower is unlimited (-1).
QW_GRID_EXPORT_LIMIT_W=15000
# How often (seconds) to refresh telemetry from dbus.
QW_TELEMETRY_INTERVAL_S=5

# --- Optional local MQTT bridge (Node-RED / dashboards) ---------------------
# The pure-Python path does NOT need this. Set to 1 only if a Node-RED flow or a
# dashboard should consume the decoded WORKMODE from a local broker. It also
# publishes the derived mFRR event state ("<prefix>/mfrr_active" on/off +
# "<prefix>/mfrr_signed_w") so a Node-RED PV-curtailment flow can STAND DOWN
# (hold the inverter at 100%) while mFRR owns the grid setpoint — otherwise the
# curtailment loop would fight an frr-up export / frr-down import.
QW_LOCAL_BRIDGE=0
LOCAL_MQTT_HOST=127.0.0.1
LOCAL_MQTT_PORT=1883
# Leave user/pass empty if the local broker allows anonymous localhost access.
LOCAL_MQTT_USER=
LOCAL_MQTT_PASS=
QW_LOCAL_PREFIX=qw

# --- Logging ----------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
QW_LOG_LEVEL=INFO

# =============================================================================
# Example — site A (DC-coupled, asymmetric 28 kW import / 15 kW export):
#   QW_TELEMETRY_PROFILE=dc_coupled
#   QW_MAX_IMPORT_W=28000
#   QW_MAX_EXPORT_W=15000
#   QW_GRID_EXPORT_LIMIT_W=15000
#   QW_LOCAL_BRIDGE=0          # no Node-RED — pure Python state machine
# =============================================================================
